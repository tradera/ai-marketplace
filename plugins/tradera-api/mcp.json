{
  "mcpServers": {
    "tradera": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/server.mjs"],
      "env": {
        "TRADERA_APP_ID": "${TRADERA_APP_ID}",
        "TRADERA_APP_KEY": "${TRADERA_APP_KEY}",
        "TRADERA_USER_ID": "${TRADERA_USER_ID}",
        "TRADERA_USER_TOKEN": "${TRADERA_USER_TOKEN}",
        "TRADERA_API_BASE": "${TRADERA_API_BASE}"
      }
    }
  }
}
